# GRAMGPT PRODUCTION ENVIRONMENT
# Copy to .env.prod and fill in ALL values before deployment

# --- Domain & SSL (Required for Traefik) ---
DOMAIN=yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# --- Database (PostgreSQL) ---
DB_USER=gramgpt_user
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD_123
DB_NAME=gramgpt_prod

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_456

# --- Telegram API (User Bot) ---
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890

# --- AI Providers ---
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# --- Security ---
JWT_SECRET=CHANGE_ME_JWT_SECRET_789
ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY_BASE64

# --- Celery ---
CELERY_BROKER_URL=redis://:CHANGE_ME_REDIS_PASSWORD_456@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_REDIS_PASSWORD_456@redis:6379/1

# --- S3 Storage (Optional) ---
S3_ENDPOINT=https://storage.yourprovider.com
S3_BUCKET=gramgpt-media
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# --- Monitoring ---
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# --- Payment Gateway (Optional) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_ACCOUNT=50

# --- Anti-Ban Thresholds ---
BAN_RISK_THRESHOLD=0.7
MAX_CONSECUTIVE_ERRORS=3
