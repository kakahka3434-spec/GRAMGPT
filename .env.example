# === GRAMGPT Configuration ===
# Copy to .env.local and fill in your values

# --- Telegram User API (Telethon) — required for parsing/commenting ---
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=23658639
TELEGRAM_API_HASH=cfb36ccc9fda771f58107ab86642098c
# Phone number with country code (used for user API auth)
TELEGRAM_PHONE=

# --- AI Provider (at least one required) ---
# Provider: openai, openrouter, or groq
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# --- Optional: Redis (for distributed task queue) ---
# If not configured, tasks run inline (no Redis needed)
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Optional: Telegram Bot (aiogram) ---
BOT_TOKEN=

# --- Server ---
PORT=8000
SECRET_KEY=your-secret-key-change-in-production
