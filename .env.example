# Local environment variables (DO NOT COMMIT)
# Copy this file to .env.local and fill with your values

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=

# AI Provider: openai, openrouter, groq, or none (for testing)
AI_PROVIDER=openrouter

# OpenAI API Key (leave empty if using free alternatives)
OPENAI_API_KEY=

# OpenRouter (free tier available) - https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq (free tier available) - https://console.groq.com/keys
GROQ_API_KEY=

# Telegram User API credentials (from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=

# Model Settings
MODEL_NAME=mistralai/mistral-7b-instruct:free
TEMPERATURE=0.7
MAX_TOKENS=2000
SYSTEM_PROMPT=\
You
are
GRAMGPT
advanced
AI
system
for
Telegram
automation
and
marketing.\
